    <worksheet name='Net Financial Assistance'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontsize='9'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Dim_Time+ (Master_Tables_file)' name='federated.1c300ul0867lez170sibc0ki6xp2' />
          </datasources>
          <datasource-dependencies datasource='federated.1c300ul0867lez170sibc0ki6xp2'>
            <column caption='Airline Name' datatype='string' name='[Airline_Name]' role='dimension' type='nominal' />
            <column caption='Cares Flag' datatype='string' name='[CARES_FLAG]' role='dimension' type='nominal' />
            <column caption='Bailout Cushion' datatype='real' name='[Calculation_1236972364541953]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [CARES_FLAG] = &apos;CARES_Period&apos; THEN [net_income] - [operating_income] END)' />
            </column>
            <column caption='Is Delta?' datatype='boolean' name='[Calculation_1236972380856322]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Airline_Name] = &quot;Delta Airlines&quot;' />
            </column>
            <column caption='Net Income' datatype='integer' default-format='C1033%' name='[net_income]' role='measure' type='quantitative' />
            <column-instance column='[Airline_Name]' derivation='None' name='[none:Airline_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[CARES_FLAG]' derivation='None' name='[none:CARES_FLAG:nk]' pivot='key' type='nominal' />
